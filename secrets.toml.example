# ============================================================
# نموذج ملف الأسرار لـ Streamlit Cloud
# في لوحة تحكم Streamlit Cloud:
#   Settings → Secrets → الصق هذا المحتوى بقيمه الحقيقية
# ============================================================

ZR_API_KEY    = "YOUR_ZR_API_KEY_HERE"
ZR_TENANT_ID  = "YOUR_ZR_TENANT_ID_HERE"
ZR_BASE_URL   = "https://api.zrexpress.app/api/v1"

[gcp_service_account]
type                        = "service_account"
project_id                  = "YOUR_PROJECT_ID"
private_key_id              = "YOUR_PRIVATE_KEY_ID"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY\n-----END RSA PRIVATE KEY-----\n"
client_email                = "your-service@your-project.iam.gserviceaccount.com"
client_id                   = "YOUR_CLIENT_ID"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "YOUR_CERT_URL"
